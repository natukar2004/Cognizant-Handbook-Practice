SET SERVEROUTPUT ON;

DECLARE
    -- Explicit cursor: all transactions in the current calendar month,
    -- ordered by customer so each customer's rows are grouped together.
    CURSOR GenerateMonthlyStatements IS
        SELECT t.customer_id,
               c.customer_name,
               t.transaction_id,
               t.txn_date,
               t.txn_type,
               t.amount
        FROM   transactions t
        JOIN   customers c ON c.customer_id = t.customer_id
        WHERE  t.txn_date >= TRUNC(SYSDATE, 'MM')          -- first day of this month
        AND    t.txn_date <  ADD_MONTHS(TRUNC(SYSDATE, 'MM'), 1) -- before next month starts
        ORDER  BY t.customer_id, t.txn_date;

    v_current_customer   customers.customer_id%TYPE := -1; -- sentinel: no customer yet
    v_customer_total     NUMBER := 0;

BEGIN
    FOR rec IN GenerateMonthlyStatements LOOP

        -- New customer encountered: close out the previous customer's
        -- statement (if any) and start a new one.
        IF rec.customer_id != v_current_customer THEN
            IF v_current_customer != -1 THEN
                DBMS_OUTPUT.PUT_LINE('  -------------------------------');
                DBMS_OUTPUT.PUT_LINE('  Statement total: ' || v_customer_total);
                DBMS_OUTPUT.PUT_LINE(' ');
            END IF;

            DBMS_OUTPUT.PUT_LINE('Statement for: ' || rec.customer_name
                                  || ' (Customer ID: ' || rec.customer_id || ')');
            v_current_customer := rec.customer_id;
            v_customer_total := 0;
        END IF;

        DBMS_OUTPUT.PUT_LINE('  ' || TO_CHAR(rec.txn_date, 'YYYY-MM-DD')
                              || ' | ' || RPAD(rec.txn_type, 10)
                              || ' | Amount: ' || rec.amount);

        v_customer_total := v_customer_total + rec.amount;
    END LOOP;

    -- Print the final customer's total after the loop ends.
    IF v_current_customer != -1 THEN
        DBMS_OUTPUT.PUT_LINE('  -------------------------------');
        DBMS_OUTPUT.PUT_LINE('  Statement total: ' || v_customer_total);
    ELSE
        DBMS_OUTPUT.PUT_LINE('No transactions found for the current month.');
    END IF;

EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('No data found while generating statements.');
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Unexpected error generating statements: ' || SQLERRM);
END;
/



SET SERVEROUTPUT ON;

DECLARE
    CURSOR ApplyAnnualFee IS
        SELECT account_id, balance
        FROM   accounts
        FOR UPDATE OF balance; -- lock rows as we go, since we're updating them

    c_annual_fee   CONSTANT NUMBER := 50; -- flat annual maintenance fee
    v_new_balance  NUMBER;
    v_accounts_updated NUMBER := 0;
    v_accounts_skipped NUMBER := 0;

BEGIN
    FOR rec IN ApplyAnnualFee LOOP
        BEGIN
            v_new_balance := rec.balance - c_annual_fee;

            IF v_new_balance < 0 THEN
                -- Business rule: don't push an account negative from the fee alone.
                -- Skip it and flag for manual review rather than silently overdrawing.
                DBMS_OUTPUT.PUT_LINE('Skipped account ' || rec.account_id
                                      || ': balance ' || rec.balance
                                      || ' insufficient for fee ' || c_annual_fee);
                v_accounts_skipped := v_accounts_skipped + 1;
            ELSE
                UPDATE accounts
                SET    balance = v_new_balance
                WHERE  CURRENT OF ApplyAnnualFee;

                v_accounts_updated := v_accounts_updated + 1;
            END IF;

        EXCEPTION
            WHEN OTHERS THEN
                -- Isolate failures per account: log and continue rather than
                -- letting one bad row roll back fee collection for everyone.
                DBMS_OUTPUT.PUT_LINE('Error applying fee to account '
                                      || rec.account_id || ': ' || SQLERRM);
                v_accounts_skipped := v_accounts_skipped + 1;
        END;
    END LOOP;

    COMMIT;

    DBMS_OUTPUT.PUT_LINE('Annual fee run complete. Updated: '
                          || v_accounts_updated || ', Skipped: ' || v_accounts_skipped);

EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('Fatal error during annual fee run, rolled back: ' || SQLERRM);
END;
/